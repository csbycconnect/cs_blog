{
  "rewrites": [
    {
      "source": "/api/articles/like",
      "destination": "/api/articles/like.js"
    },
    {
      "source": "/api/articles/views",
      "destination": "/api/articles/views.js"
    },
    {
      "source": "/api/articles/details",
      "destination": "/api/articles/details.js"
    },
    {
      "source": "/api/articles",
      "destination": "/api/articles/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}